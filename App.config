<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
  <connectionStrings>
    <add name="WasteDB" 
         connectionString="Data Source=SmartWaste.db;Version=3;" 
         providerName="System.Data.SQLite" />
  </connectionStrings>
  <appSettings>
    <add key="AppName" value="Smart Waste Management System" />
    <add key="Version" value="1.0.0" />
    <add key="Company" value="CodeSmashers" />
  </appSettings>
</configuration>
